{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mailbox Viewer",
  "version": "0.1.0",
  "identifier": "local.mailbox.viewer",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mailbox Viewer",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
